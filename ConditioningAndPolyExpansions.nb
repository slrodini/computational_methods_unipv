Cell[BoxData[
 RowBox[{
  RowBox[{"lj", "[", 
   RowBox[{"j_", ",", "x_", ",", "ys_"}], "]"}], ":=", 
  RowBox[{"Product", "[", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"i", "!=", "j"}], ",", 
      FractionBox[
       RowBox[{"x", "-", 
        RowBox[{"ys", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], 
       RowBox[{
        RowBox[{"ys", "[", 
         RowBox[{"[", "j", "]"}], "]"}], "-", 
        RowBox[{"ys", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}]], ",", "1"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", 
      RowBox[{"Length", "[", "ys", "]"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.982491195118817*^9, 3.982491257685815*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"579f358c-4f97-4caf-bed7-6f9908fbb872"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"resultsEquispaced", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"resultsChebyshev", "=", 
   RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Monitor", "[", 
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"deg", "=", "5"}], ",", 
     RowBox[{"deg", "<=", "15"}], ",", 
     RowBox[{"deg", "+=", "1"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"xs", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", 
           FractionBox[
            RowBox[{"i", "-", "1"}], 
            RowBox[{"deg", "-", "1"}]]}], "-", "1"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "deg"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"xsCh", " ", "=", " ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Cos", "[", 
          RowBox[{
           FractionBox[
            RowBox[{"i", "-", "1"}], 
            RowBox[{"deg", "-", "1"}]], "\[Pi]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "deg"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"s", " ", "=", " ", 
       RowBox[{"SingularValueList", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"lj", "[", 
              RowBox[{"i", ",", "x", ",", "xs"}], "]"}], 
             RowBox[{"lj", "[", 
              RowBox[{"j", ",", "x", ",", "xs"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", 
              RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "xs", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"Length", "[", "xs", "]"}]}], "}"}]}], "]"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"\[Kappa]", " ", "=", " ", 
       RowBox[{
        RowBox[{"Max", "[", "s", "]"}], "/", 
        RowBox[{"Min", "[", "s", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"resultsEquispaced", ",", 
        RowBox[{"{", 
         RowBox[{"deg", ",", "\[Kappa]"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"s", " ", "=", " ", 
       RowBox[{"SingularValueList", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"NIntegrate", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"lj", "[", 
              RowBox[{"i", ",", "x", ",", "xsCh"}], "]"}], 
             RowBox[{"lj", "[", 
              RowBox[{"j", ",", "x", ",", "xsCh"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", 
              RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"Length", "[", "xs", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"Length", "[", "xs", "]"}]}], "}"}]}], "]"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"\[Kappa]", " ", "=", " ", 
       RowBox[{
        RowBox[{"Max", "[", "s", "]"}], "/", 
        RowBox[{"Min", "[", "s", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"resultsChebyshev", ",", 
        RowBox[{"{", 
         RowBox[{"deg", ",", "\[Kappa]"}], "}"}]}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}], ",", "deg"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9824912628210564`*^9, 3.98249133032603*^9}, {
  3.9824913739619627`*^9, 3.982491388123074*^9}, {3.9824915098732443`*^9, 
